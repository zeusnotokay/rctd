# Enforce HTTPS Redirect
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Security Headers Configuration
<IfModule mod_headers.c>
    # Prevent Clickjacking (disallow loading page in iframes from other domains)
    Header set X-Frame-Options "SAMEORIGIN"
    
    # Prevent MIME Sniffing (block browser from executing non-script files as scripts)
    Header set X-Content-Type-Options "nosniff"
    
    # Force XSS filter block on older browsers
    Header set X-XSS-Protection "1; mode=block"
    
    # Referrer policy (limit referrer leakage to third parties)
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Secure Content Security Policy (CSP) for static site operations
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://rc-thanedowntown.weebly.com; frame-src 'self' https://www.google.com https://calendar.google.com; connect-src 'self';"
</IfModule>
